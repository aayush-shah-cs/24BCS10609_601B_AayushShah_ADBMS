-- AGGREGATE FUNCTION -> SUM(),MIN(),MAX(),AVG(),COUNT()


-- COUNT THE NUMBER OF EMPLOYEES IN EACH CITY

-- (I) 
SELECT EMP_CITY,COUNT(*) AS CNT FROM EMPLOYEES
GROUP BY EMP_CITY

-- (II)
SELECT EMP_CITY,COUNT(EMP_ID) AS CNT FROM EMPLOYEES
GROUP BY EMP_CITY


-- COUNT THRE NUMBER OF EMPLOYEE IN EACH CITY WHOSE SALARY SALARY IS GRETARE THAN EQUAL TO 90000


SELECT EMP_CITY,SUM(CASE WHEN EMP_SALARY>=90000 THEN 1 ELSE 0 END) AS CNT FROM EMPLOYEES
GROUP BY EMP_CITY



-- COUNT THRE NUMBER OF EMPLOYEE IN EACH CITY WHOSE SALARY SALARY IS GRETARE THAN EQUAL TO 90000
-- AND SORT ON THE BASIS OF CITY NAME IN DESCENDING ORDER


SELECT EMP_CITY,SUM(CASE WHEN EMP_SALARY>=90000 THEN 1 ELSE 0 END) AS CNT FROM EMPLOYEES
GROUP BY EMP_CITY
ORDER BY EMP_CITY DESC


-- COUNT THRE NUMBER OF EMPLOYEE IN EACH CITY WHOSE SALARY SALARY IS GRETARE THAN EQUAL TO 90000
-- AND SORT ON THE BASIS OF CNT IN DESC ORDER


SELECT EMP_CITY,SUM(CASE WHEN EMP_SALARY>=90000 THEN 1 ELSE 0 END) AS CNT FROM EMPLOYEES
GROUP BY EMP_CITY
ORDER BY CNT DESC,EMP_CITY DESC


-- FIND THE NAME OF THE CITY WHOSE EMPLOYEE COUNT AT LEAST 2

SELECT EMP_CITY AS CNT FROM EMPLOYEES
GROUP BY EMP_CITY
HAVING COUNT(EMP_ID)>=2



-- 
-- DISTINCT

SELECT DISTINCT EMP_CITY
FROM EMPLOYEES
